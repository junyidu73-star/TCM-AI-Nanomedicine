# =============================================================================
#  .gitignore  ——  中药多组学计算辅助新药发现平台 (CDSS)
#  基于标准 Python 模板，并针对本项目的 MD 轨迹 / 用户上传数据做定制。
# =============================================================================

# -----------------------------------------------------------------------------
#  Python 字节码 / 缓存
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# -----------------------------------------------------------------------------
#  打包 / 构建产物
# -----------------------------------------------------------------------------
build/
dist/
*.egg-info/
.eggs/
*.egg
wheels/
.installed.cfg

# -----------------------------------------------------------------------------
#  本地虚拟环境 / 包管理器目录
# -----------------------------------------------------------------------------
venv/
.venv/
env/
.env
ENV/
miniconda3/
anaconda3/
conda-env/
.conda/

# -----------------------------------------------------------------------------
#  MD 结构 / 轨迹等大体积临时文件（不应进入仓库）
# -----------------------------------------------------------------------------
*.gro
*.xtc
*.trr
*.edr
*.cpt
*.tpr
*.log
prod.*
#  MDAnalysis 轨迹偏移量缓存（由 .xtc 自动生成，随轨迹重建）
*_offsets.npz
.*_offsets.npz
#  注意：*.top 拓扑作为演示配置默认保留在版本控制中；
#  如需忽略自动生成的酸性拓扑，取消下一行注释：
# *_acidic.top

# -----------------------------------------------------------------------------
#  用户上传的临时测试数据 / 运行时产物
# -----------------------------------------------------------------------------
data_uploads/*.csv
data_uploads/*.tsv
data_uploads/*.xlsx
results/
downloaded_sdf/
*.sdf
*.pdbqt

#  运行时生成的网络边列表（由 docking_network 产出，非源码）
drug_target_pathway_network.csv

#  MDAnalysis 轨迹偏移缓存（由 .xtc 自动再生，非源码）
.*_offsets.npz
*_offsets.npz

#  生成的图像产物（如需保留示例图，可对具体文件用 !filename.png 反忽略）
core_shell_heatmap.png
radial_density_profile.png

# -----------------------------------------------------------------------------
#  测试 / 覆盖率 / 类型检查缓存
# -----------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# -----------------------------------------------------------------------------
#  Jupyter / IPython
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
profile_default/
ipython_config.py

# -----------------------------------------------------------------------------
#  Streamlit 本地密钥（严禁上传）
# -----------------------------------------------------------------------------
.streamlit/secrets.toml

# -----------------------------------------------------------------------------
#  IDE / 编辑器
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
#  操作系统杂项
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
